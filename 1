        .inner {
            padding: 28px 24px;
            position: relative;
        }
        .sakura-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            overflow: hidden;
            z-index: 0;
        }
        .petal {
            position: absolute;
            background: #ffafc2;
            width: 10px;
            height: 10px;
            border-radius: 70% 30% 65% 35%;
            opacity: 0.45;
            animation: fall 12s linear infinite;
        }
        @keyframes fall {
            0% { transform: translateY(-20px) rotate(0deg); opacity: 0; }
            15% { opacity: 0.65; }
            85% { opacity: 0.4; }
            100% { transform: translateY(650px) rotate(320deg); opacity: 0; }
