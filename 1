        @keyframes pulse { 100% { text-shadow: 0 0 8px #ff6622; } }
        .unit {
            font-size: 1.4rem;
            font-weight: bold;
            color: #ffcc88;
        }
        .daily {
            background: linear-gradient(95deg, #ff3c2e20, #ff9f2e30);
            border-radius: 56px;
            padding: 8px 16px;
            text-align: center;
            border: 1px solid #ffbc7a;
            margin: 10px 0;
            position: relative;
            z-index: 2;
        }
        .daily strong {
            font-size: 1.9rem;
            font-weight: 900;
            color: #ffcf7a;
            text-shadow: 0 0 5px #ff7a00;
            margin: 0 5px;
        }
        .services {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin: 20px 0 10px;
            justify-content: center;
            position: relative;
            z-index: 2;
        }
        .services span {
            background: rgba(0,0,0,0.65);
            padding: 6px 14px;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 600;
            color: #ffdbb5;
            backdrop-filter: blur(4px);
            border-right: 2px solid #ff7e4a;
        }
        .btn {
            background: linear-gradient(115deg, #e85f2c, #cc2b5e);
            margin: 20px 20px 25px;
            padding: 16px 12px;
            border-radius: 70px;
            text-align: center;
            font-weight: 800;
            font-size: 1.5rem;
            color: #fff3e0;
            text-decoration: none;
            display: block;
            box-shadow: 0 8px 18px rgba(0,0,0,0.4);
            position: relative;
            z-index: 2;
        }
        .btn:active { transform: scale(0.98); }
        .btn small {
            display: block;
            font-size: 0.7rem;
            margin-top: 5px;
        }
        .footer {
            text-align: center;
            padding: 12px 20px 22px;
            font-size: 0.65rem;
            color: #b4aad6;
            background: rgba(0,0,0,0.4);
            border-top: 1px solid #3e2a2a;
            position: relative;
            z-index: 2;
        }
        .copy {
            background: #000000aa;
            display: inline-block;
            padding: 4px 12px;
            border-radius: 40px;
            margin-top: 8px;
            cursor: pointer;
        }
        .music-ctrl {
            position: fixed;
            bottom: 24px;
            right: 24px;
            background: rgba(0,0,0,0.75);
            backdrop-filter: blur(8px);
            width: 52px;
            height: 52px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 1000;
            border: 1px solid #ffaa66;
            font-size: 1.7rem;
            color: #ffddbb;
            box-shadow: 0 2px 8px rgba(0,0,0,0.3);
        }
        .music-ctrl:active { transform: scale(0.95); }
        .tip {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(12px);
            padding: 14px 28px;
            border-radius: 60px;
            font-size: 1rem;
            color: #ffdd99;
            white-space: nowrap;
            z-index: 2000;
            border: 1px solid #ffaa66;
            pointer-events: none;
            animation: fadeOut 3s forwards;
        }
        @keyframes fadeOut {
            0% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
            70% { opacity: 1; }
            100% { opacity: 0; transform: translate(-50%, -50%) scale(0.95); visibility: hidden; }
        }
        @media (max-width: 500px) {
            .inner { padding: 20px 16px; }
            h1 { font-size: 2.3rem; }
            .map-name { font-size: 1.3rem; }
            .price { font-size: 3rem; }
            .btn { font-size: 1.2rem; margin: 20px 16px 24px; }
            .music-ctrl { width: 44px; height: 44px; font-size: 1.4rem; bottom: 16px; right: 16px; }
            .tip { font-size: 0.85rem; white-space: normal; width: 80%; text-align: center; }
        }
    </style>
</head>
<body>
