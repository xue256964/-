        .badge {
            display: inline-block;
            background: rgba(0,0,0,0.7);
            backdrop-filter: blur(8px);
            padding: 6px 20px;
            border-radius: 40px;
            font-weight: 700;
            font-size: 0.8rem;
            color: #ffddbb;
            border-left: 3px solid #ff7e4a;
            margin-bottom: 20px;
            position: relative;
            z-index: 2;
        }
        h1 {
            font-size: 3.2rem;
            font-weight: 900;
            line-height: 1.2;
            background: linear-gradient(135deg, #FFF2D7, #FFBE76, #FF7A5C);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            position: relative;
            z-index: 2;
        }
        .sub {
            font-size: 0.95rem;
            background: rgba(0,0,0,0.55);
            display: inline-block;
            padding: 4px 18px;
            border-radius: 30px;
            margin-top: 12px;
            font-weight: 500;
            color: #ffdaaa;
            backdrop-filter: blur(4px);
            position: relative;
            z-index: 2;
        }
        .map-row {
            display: flex;
            gap: 20px;
            margin: 34px 0 28px;
            position: relative;
            z-index: 2;
        }
        .map {
            flex: 1;
            background: rgba(0,0,0,0.7);
            backdrop-filter: blur(8px);
            border-radius: 36px;
            padding: 18px 6px;
            text-align: center;
            border: 1px solid rgba(255,165,100,0.6);
        }
        .map-icon { font-size: 3rem; filter: drop-shadow(0 0 5px #ff7e4a); }
        .map-name {
            font-size: 1.7rem;
            font-weight: 800;
            background: linear-gradient(145deg, #FFD6A5, #FFB347);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .drops {
            font-size: 0.73rem;
