<div class="music-ctrl" id="musicToggle">🎵</div>
<audio id="bgMusic" loop preload="auto" style="display:none;"></audio>

<script>
    // 音乐地址（网易云外链直链，可能随时失效，可自行替换）
    const MUSIC_URL = "https://music.163.com/song/media/outer/url?id=1964850580.mp3";
    
    const audio = document.getElementById('bgMusic');
    const musicBtn = document.getElementById('musicToggle');
    let isPlaying = false;
    let hasUserInteracted = false;
    
    if (audio) {
        audio.src = MUSIC_URL;
        audio.loop = true;
        audio.preload = 'auto';
        audio.volume = 0.8;
        audio.addEventListener('error', function(e) {
            console.log('音乐加载失败，外链可能已失效', e);
        });
    }
    
    function playMusic() {
        if (isPlaying) return;
        audio.play().then(() => {
            isPlaying = true;
            if (musicBtn) musicBtn.innerHTML = '🎵🔊';
        }).catch(e => {
            console.log('播放失败，需要用户手势', e);
            if (musicBtn) musicBtn.innerHTML = '🎵🔇';
        });
    }
    
    function pauseMusic() {
        if (!isPlaying) return;
        audio.pause();
        isPlaying = false;
        if (musicBtn) musicBtn.innerHTML = '🎵🔇';
    }
    
    if (musicBtn) {
        musicBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            if (isPlaying) {
                pauseMusic();
            } else {
                playMusic();
            }
            hasUserInteracted = true;
        });
    }
    
    document.body.addEventListener('click', function onFirstClick() {
        if (!hasUserInteracted) {
            hasUserInteracted = true;
            playMusic();
            const tip = document.createElement('div');
            tip.className = 'tip';
            tip.innerText = '🎶 音乐已自动播放 🎶';
            document.body.appendChild(tip);
            setTimeout(() => tip.remove(), 2500);
        }
        document.body.removeEventListener('click', onFirstClick);
    });
    
    window.addEventListener('load', function() {
        setTimeout(() => {
            if (!hasUserInteracted) {
                const guide = document.createElement('div');
                guide.className = 'tip';
                guide.innerText = '🎵 点击任意位置播放《我本将心向明月》';
                document.body.appendChild(guide);
                setTimeout(() => guide.remove(), 4000);
            }
        }, 500);
        
        if (typeof window.WeixinJSBridge !== 'undefined') {
            document.addEventListener('WeixinJSBridgeReady', function() {
                if (!hasUserInteracted) {
                    playMusic();
                    hasUserInteracted = true;
                }
            }, false);
        }
    });
    
    function createSakura() {
        const container = document.getElementById('sakura');
        if (!container) return;
        for (let i = 0; i < 40; i++) {
            let petal = document.createElement('div');
            petal.classList.add('petal');
            let size = 5 + Math.random() * 12;
            petal.style.width = size + 'px';
            petal.style.height = size * 0.9 + 'px';
            petal.style.left = Math.random() * 100 + '%';
            petal.style.animationDuration = 7 + Math.random() * 12 + 's';
            petal.style.animationDelay = Math.random() * 15 + 's';
            petal.style.background = `rgba(255, ${150 + Math.random() * 100}, ${180 + Math.random() * 75}, 0.6)`;
            container.appendChild(petal);
        }
    }
    createSakura();
    
    const copyBtn = document.getElementById('copyBtn');
    if (copyBtn) {
        copyBtn.addEventListener('click', () => {
            navigator.clipboard.writeText("xd256964").then(() => {
                const original = copyBtn.innerText;
                copyBtn.innerText = '✅ 微信号已复制！ ✅';
                setTimeout(() => { copyBtn.innerText = original; }, 2000);
            }).catch(() => alert('手动复制微信号: xd256964'));
        });
    }
    
    const wechatLink = document.getElementById('wechatBtn');
    if (wechatLink) {
        wechatLink.addEventListener('click', (e) => {
            let timeout = setTimeout(() => {
                alert('若无法自动跳转微信，请点击下方微信号手动复制添加\n微信号: xd256964');
            }, 800);
            window.addEventListener('blur', () => clearTimeout(timeout));
        });
    }
</script>
</body>
