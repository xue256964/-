            z-index: 2;
        }
        .price {
            font-size: 3.8rem;
            font-weight: 900;
            background: linear-gradient(145deg, #FFDB8E, #FFA047);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
